# --- server -------------------------------------------------------------------
SERVER_PORT=8080
SERVER_ENV=development
SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=10s
SERVER_SHUTDOWN_TIMEOUT=10s

# --- postgres -----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres                    # referenced by DB_PASSWORD_REF
DB_PASSWORD_REF=env://DB_PASSWORD
DB_NAME=aether_auth
DB_SSL_MODE=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h

# --- redis (rate limiting + revocation set) -----------------------------------
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_PASSWORD_REF=env://REDIS_PASSWORD
REDIS_DB=0

# --- queue (Asynq broker, separate logical DB recommended) --------------------
QUEUE_REDIS_ADDR=localhost:6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_PASSWORD_REF=env://QUEUE_REDIS_PASSWORD
QUEUE_REDIS_DB=1
QUEUE_CONCURRENCY=10

# --- mailer (Mailpit defaults for local dev) ----------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PASSWORD_REF=env://SMTP_PASSWORD
SMTP_FROM=noreply@example.com
SMTP_STARTTLS=false

# --- issuer -------------------------------------------------------------------
ISSUER_URL=https://auth.example.com
PUBLIC_BASE_URL=https://auth.example.com
ISSUER_AUDIENCES=https://api.example.com

# --- secrets (replace these dev placeholders in production) -------------------
AUTH_PEPPER=change-me-in-prod
AUTH_AES_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
AUTH_PASETO_LOCAL_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
AUTH_PASETO_SEED=202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f
AUTH_CSRF_SECRET=change-me-in-prod-32-bytes-long
SECRET_PEPPER_REF=env://AUTH_PEPPER
SECRET_AES_KEY_REF=env://AUTH_AES_KEY
SECRET_PASETO_LOCAL_REF=env://AUTH_PASETO_LOCAL_KEY
SECRET_PASETO_SEED_REF=env://AUTH_PASETO_SEED
SECRET_CSRF_REF=env://AUTH_CSRF_SECRET

# --- argon2id (OWASP m=46MiB profile) -----------------------------------------
ARGON2_MEMORY_KIB=47104
ARGON2_ITERATIONS=1
ARGON2_PARALLELISM=1
ARGON2_SALT_LENGTH=16
ARGON2_KEY_LENGTH=32

# --- session ------------------------------------------------------------------
SESSION_ACCESS_TTL=15m
SESSION_REFRESH_SLIDING=720h
SESSION_REFRESH_ABSOLUTE=2160h
SESSION_PARTIAL_TTL=2m
SESSION_REVOCATION_CACHE_TTL=15m

# --- paseto -------------------------------------------------------------------
PASETO_ROTATION_INTERVAL=2160h
PASETO_OVERLAP_WINDOW=336h

# --- oauth server -------------------------------------------------------------
OAUTH_CODE_TTL=60s
OAUTH_ACCESS_TTL=15m
OAUTH_REFRESH_TTL=720h
OAUTH_ROTATE_REFRESH=true
OAUTH_DEFAULT_SCOPES=openid,profile
OAUTH_REQUIRE_PKCE=true

# --- rate limits --------------------------------------------------------------
RATELIMIT_IP_PER_MIN=100
RATELIMIT_ACCOUNT_PER_MIN=10
RATELIMIT_RESET_PER_MIN=5

# --- lockout / progressive backoff -------------------------------------------
LOCKOUT_FAILURES=5
LOCKOUT_BACKOFF=1m,5m,15m,1h
LOCKOUT_CAPTCHA_AFTER=3

# --- HIBP breach corpus check -------------------------------------------------
HIBP_ENABLED=true
HIBP_BASE_URL=https://api.pwnedpasswords.com
HIBP_CACHE_TTL=24h

# --- CSRF (synchronizer-token cookie/header pair) ----------------------------
CSRF_COOKIE=XSRF-TOKEN
CSRF_HEADER=X-XSRF-TOKEN

# --- CORS ---------------------------------------------------------------------
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Authorization,Content-Type,X-XSRF-TOKEN

# --- audit --------------------------------------------------------------------
AUDIT_SINK=db

# --- logging ------------------------------------------------------------------
LOG_DEVELOPMENT=true
LOG_LEVEL=info

# --- organizations ------------------------------------------------------------
ORG_DEFAULT_ROLE=member
ORG_INVITATION_TTL=168h
